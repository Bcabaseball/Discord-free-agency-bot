    @app_commands.command(name="offer", description="Submit contract offer to a free agent")
    async def make_offer(self, interaction: discord.Interaction, player_name: str, years: int, aav: int):
        """Submit contract offer"""
        user_team, team_data = get_user_team(interaction.user.id)
        if not user_team:
            await interaction.response.send_message("❌ You are not assigned to any team.", ephemeral=True)
            return
        
        settings = load_json(SETTINGS_FILE)
        # Check if free agency is active
        if not settings.get("fa_active", False):
            await interaction.response.send_message("❌ Free agency is not active.", ephemeral=True)
            return
        
        # Find player (case-insensitive)
        free_agents = load_json(FREE_AGENTS_FILE)
        player_id, player = find_player(free_agents, player_name, status="available")
        
        if not player:
            await interaction.response.send_message(f"❌ Player '{player_name}' not found or already signed.", ephemeral=True)
            return
        
        # Validate years
        if years < 1 or years > 10:
            await interaction.response.send_message("❌ Contract years must be between 1 and 10.", ephemeral=True)
            return
        
        # Validate salary range
        salary_range = get_salary_range(player["ovr"])
        if aav < salary_range["min"] or aav > salary_range["max"]:
            await interaction.response.send_message(
                f"❌ Invalid salary. {player['name']} (OVR {player['ovr']}) requires ${salary_range['min']:,} - ${salary_range['max']:,} per year.",
                ephemeral=True
            )
            return
        
        # Check cap space
        cap_manager = CapManager(user_team)
        if not cap_manager.can_make_offer(aav):
            available = cap_manager.get_available_cap()
            await interaction.response.send_message(
                f"❌ Insufficient cap space. You have ${available:,} available, but this offer requires ${aav:,}/year.",
                ephemeral=True
            )
            return
        
        # Check for duplicate offers
        offers = load_json(OFFERS_FILE)
        for offer_id, offer in offers.items():
            if (offer["team"] == user_team and 
                offer["player_id"] == player_id and 
                offer["status"] == "pending"):
                await interaction.response.send_message(
                    f"❌ You already have a pending offer for {player['name']}. Withdraw it before submitting a new one.",
                    ephemeral=True
                )
                return
        
        # Get market data
        market_data = load_json(MARKET_FILE)
        
        # Create offer
        offer_id = str(uuid.uuid4())
        offer = {
            "id": offer_id,
            "player_id": player_id,
            "player_name": player["name"],
            "team": user_team,
            "gm_id": interaction.user.id,
            "aav": aav,
            "years": years,
            "total_value": aav * years,
            "timestamp": datetime.now().isoformat(),
            "expires": (datetime.now() + timedelta(hours=48)).isoformat(),
            "status": "pending",
            "decision_score": 0,
            "counter_offers": [],
            "final_decision": None
        }
        
        # Calculate score
        decision_engine = DecisionEngine()
        score = decision_engine.calculate_offer_score(offer, player, team_data, market_data)
        offer["decision_score"] = score
        
        # Save offer
        offers[offer_id] = offer
        save_json(OFFERS_FILE, offers)
        
        # Update player offer count
        player["offer_count"] = player.get("offer_count", 0) + 1
        if "best_offer" not in player or aav > player["best_offer"]["aav"]:
            player["best_offer"] = {
                "team": user_team,
                "aav": aav,
                "years": years
            }
        save_json(FREE_AGENTS_FILE, free_agents)
        
        # Update market data
        market_data["total_offers_made"] += 1
        save_json(MARKET_FILE, market_data)
        
        log_action("offer_made", f"{user_team} offered {player['name']} {years}/${aav}")
        
        # Create negotiation thread
        try:
            thread = await interaction.channel.create_thread(
                name=f"FA: {player['name']} - {user_team}",
                type=discord.ChannelType.public_thread,
                auto_archive_duration=1440
            )
            
            # Store thread info
            negotiations = load_json(NEGOTIATIONS_FILE)
            negotiations[offer_id] = {
                "thread_id": thread.id,
                "channel_id": thread.parent_id,
                "player": player["name"],
                "team": user_team,
                "offer_id": offer_id,
                "messages": []
            }
            save_json(NEGOTIATIONS_FILE, negotiations)
            
            # Send initial message
            await thread.send(f"**Negotiations with {player['name']}**\n\nOffer: {years} years at ${aav:,}/year (${aav * years:,} total)\nScore: {score:.1%}")
            
            # Check if agent should counter or accept
            action = decision_engine.should_counter(score)
            
            if action == "accept":
                # Auto-accept for strong offers
                await thread.send(f"✅ {generate_accept_message(player['personality'])}")
                await self.process_signing(interaction, offer, player, thread)
            elif action in ["counter_aggressive", "counter_moderate"]:
                # Generate counter offer
                counter = decision_engine.generate_counter_offer(offer, score, player["personality"], market_data["current_stage"])
                if counter:
                    await thread.send(f"**Agent Response:**\n{counter['message']}\n\n**Counter Offer:** {counter['years']} years at ${counter['aav']:,}/year")
                    offer["counter_offers"].append(counter)
                    save_json(OFFERS_FILE, offers)
            else:
                await thread.send(f"**Agent Response:** I'm considering your offer. Will respond within 48 hours.")
            
            await interaction.response.send_message(f"✅ Offer submitted! Negotiation thread created: {thread.mention}", ephemeral=True)
            
        except Exception as e:
            await interaction.response.send_message(f"✅ Offer submitted! Check your DMs for updates.", ephemeral=True)
            print(f"Error creating thread: {e}")
    
    async def process_signing(self, interaction, offer, player, thread):
        """Process a player signing"""
        # Update player status
        free_agents = load_json(FREE_AGENTS_FILE)
        player["status"] = "signed"
        player["signed_team"] = offer["team"]
        player["signed_aav"] = offer["aav"]
        player["signed_years"] = offer["years"]
        save_json(FREE_AGENTS_FILE, free_agents)
        
        # Update team cap space
        teams = load_json(TEAMS_FILE)
        teams[offer["team"]]["cap_space"] -= offer["aav"]
        save_json(TEAMS_FILE, teams)
        
        # Update offer status
        offers = load_json(OFFERS_FILE)
        if offer["id"] in offers:
            offers[offer["id"]]["status"] = "accepted"
            offers[offer["id"]]["final_decision"] = "accepted"
            offers[offer["id"]]["aav"] = offer["aav"]
            offers[offer["id"]]["years"] = offer["years"]
            offers[offer["id"]]["total_value"] = offer["total_value"]
        
        # Update market data
        market_data = load_json(MARKET_FILE)
        market_data["total_signings"] += 1
        save_json(MARKET_FILE, market_data)
        
        # Reject all other offers for this player
        for oid, o in offers.items():
            if o["player_id"] == offer["player_id"] and o["status"] == "pending" and o["id"] != offer["id"]:
                o["status"] = "rejected"
                # Notify other GMs
                await self.notify_gm(o["gm_id"], f"❌ {player['name']} has signed with the {offer['team']}. Your offer was rejected.")
        save_json(OFFERS_FILE, offers)
        
        log_action("signing", f"{player['name']} signed with {offer['team']}")
        
        if thread:
            await thread.send(f"🎉 **SIGNING ANNOUNCEMENT** 🎉\n\n{player['name']} has officially signed with the {offer['team']}!\nContract: {offer['years']} years, ${offer['aav']:,}/year\n\nWelcome to the team!")
    
