@bot.tree.command(name="fa_logs", description="View the paginated audit log of all FA actions")
async def fa_logs(interaction: discord.Interaction, action_filter: Optional[str] = None, limit: int = 100):
    if not await check_admin(interaction):
        return

    raw_logs = load_json(LOGS_FILE)
    if not isinstance(raw_logs, list):
        raw_logs = []

    filtered = raw_logs
    if action_filter:
        filtered = [e for e in raw_logs if action_filter.lower() in e.get("action", "").lower()]

    filtered = list(reversed(filtered))[:max(1, min(limit, 500))]

    if not filtered:
        await interaction.response.send_message("📋 No log entries found.", ephemeral=True)
        return

    rows = []
    for entry in filtered:
        ts = entry.get("timestamp", "?")
        action = entry.get("action", "unknown")
        detail = entry.get("detail", "")
        try:
            dt = datetime.fromisoformat(ts)
            ts_display = dt.strftime("%m/%d %H:%M")
        except Exception:
            ts_display = ts[:16] if len(ts) >= 16 else ts
        rows.append(f"`{ts_display}` **{action}** — {detail}")

    title = f"📋 Audit Log" + (f" (filtered: `{action_filter}`)" if action_filter else "")
    desc = f"Showing **{len(rows)}** entries (most recent first)"
    pages = make_pages(title, discord.Color.dark_gray(), rows, per_page=10, description=desc)
    view = PaginatorView(pages) if len(pages) > 1 else None
    await interaction.response.send_message(embed=pages[0], view=view, ephemeral=True)


