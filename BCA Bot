    @app_commands.command(name="list", description="View all free agents")
    async def list_fa(self, interaction: discord.Interaction, ovr_min: Optional[int] = None, position: Optional[str] = None):
        """List free agents with filters"""
        free_agents = load_json(FREE_AGENTS_FILE)
        
        if not free_agents:
            await interaction.response.send_message("No free agents available.", ephemeral=True)
            return
        
        # Filter players
        players = []
        for player_id, player in free_agents.items():
            if player["status"] != "available":
                continue
            
            if ovr_min and player["ovr"] < ovr_min:
                continue
            
            if position and player["position"] != position:
                continue
            
            players.append(player)
        
        if not players:
            await interaction.response.send_message("No players match your filters.", ephemeral=True)
            return
        
        # Sort by OVR
        players.sort(key=lambda x: x["ovr"], reverse=True)
        
        embed = discord.Embed(
            title="📊 Free Agents",
            description=f"Showing {len(players)} players",
