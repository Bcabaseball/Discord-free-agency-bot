        embed = discord.Embed(title="📦 Trade Offer Sent", color=discord.Color.blurple())
        embed.add_field(name="To", value=canonical_target, inline=True)
        embed.add_field(name="You're Offering", value=f"**{your_p['name']}** ({your_p['position']}, OVR {your_p['ovr']})", inline=False)
