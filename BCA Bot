    @app_commands.command(name="accept_counter", description="Accept a player's counter offer")
    async def accept_counter(self, interaction: discord.Interaction, player_name: str):
        """Accept a counter offer from a free agent"""
        user_team, _ = get_user_team(interaction.user.id)
        if not user_team:
            await interaction.response.send_message("❌ You are not assigned to any team.", ephemeral=True)
            return

        # Check free agency is active
        settings = load_json(SETTINGS_FILE)
        if not settings.get("fa_active", False):
            await interaction.response.send_message("❌ Free agency is not active.", ephemeral=True)
            return

        # Find the player (case-insensitive)
        free_agents = load_json(FREE_AGENTS_FILE)
        player_id, player = find_player(free_agents, player_name)

        if not player:
            await interaction.response.send_message(f"❌ Player '{player_name}' not found.", ephemeral=True)
            return

        if player["status"] != "available":
            await interaction.response.send_message(f"❌ {player['name']} is no longer available.", ephemeral=True)
            return

        # Find the pending offer from this GM for this player
        offers = load_json(OFFERS_FILE)
        target_offer = None
        target_offer_id = None
        for offer_id, offer in offers.items():
            if (offer["team"] == user_team and
                    offer["player_id"] == player_id and
                    offer["status"] == "pending"):
                target_offer = offer
                target_offer_id = offer_id
                break

        if not target_offer:
            await interaction.response.send_message(
                f"❌ You have no pending offer for {player['name']}. Submit one with `/fa offer` first.",
                ephemeral=True
            )
            return

        # Check there is actually a counter offer to accept
        counters = target_offer.get("counter_offers", [])
        if not counters:
            await interaction.response.send_message(
                f"❌ {player['name']} has not countered your offer yet.",
                ephemeral=True
            )
            return

        # Take the latest counter
        latest_counter = counters[-1]
        counter_aav = latest_counter["aav"]
        counter_years = latest_counter["years"]

        # Check cap space for the new amount
        cap_manager = CapManager(user_team)
        # Available cap currently has the original offer reserved; check if counter fits
        current_offer_aav = target_offer["aav"]
        extra_needed = counter_aav - current_offer_aav
        available = cap_manager.get_available_cap()
        if extra_needed > available:
            await interaction.response.send_message(
                f"❌ Not enough cap space. Counter requires ${counter_aav:,}/yr but you only have ${available + current_offer_aav:,} available.",
                ephemeral=True
            )
            return

        # Update offer terms to the counter's terms
        target_offer["aav"] = counter_aav
        target_offer["years"] = counter_years
        target_offer["total_value"] = counter_aav * counter_years

        # Find the negotiation thread
        negotiations = load_json(NEGOTIATIONS_FILE)
        thread = None
        if target_offer_id in negotiations:
            try:
                thread_id = negotiations[target_offer_id]["thread_id"]
                thread = await interaction.client.fetch_channel(thread_id)
            except Exception:
                thread = None

        # Process the signing
        await self.process_signing(interaction, target_offer, player, thread)

        embed = discord.Embed(
            title="🤝 Counter Offer Accepted!",
            description=f"You accepted **{player['name']}**'s counter offer.",
            color=discord.Color.green()
        )
        embed.add_field(name="Team", value=user_team, inline=True)
        embed.add_field(name="Years", value=str(counter_years), inline=True)
        embed.add_field(name="AAV", value=f"${counter_aav:,}/yr", inline=True)
        embed.add_field(name="Total Value", value=f"${counter_aav * counter_years:,}", inline=True)

        await interaction.response.send_message(embed=embed)

