            return

        offers = load_json(OFFERS_FILE)
        matched_oid = None
        matched_offer = None
        for oid, o in offers.items():
            if o["team"] == canonical and o["player_id"] == player_id and o["status"] == "pending":
                matched_oid = oid
                matched_offer = o
                break

