@tasks.loop(hours=1)
async def check_expired_offers():
    """Check for expired offers every hour"""
    offers = load_json(OFFERS_FILE)
    settings = load_json(SETTINGS_FILE)
    
    if not settings.get("fa_active", False):
        return
    
    now = datetime.now()
    expired = []
    
    for offer_id, offer in offers.items():
        if offer["status"] == "pending":
            expires = datetime.fromisoformat(offer["expires"])
            if now > expires:
                expired.append(offer)
    
    for offer in expired:
        # Update offer status
        offer["status"] = "expired"
        
        # Notify GM
        try:
            user = await bot.fetch_user(offer["gm_id"])
            await user.send(f"⏰ Your offer for {offer['player_name']} has expired.")
        except:
            pass
        
        # If this was the best offer, adjust player demands
        free_agents = load_json(FREE_AGENTS_FILE)
        player = free_agents.get(offer["player_id"])
        if player and player.get("best_offer") == offer:
            # Lower demands slightly
            player["market_value"] = int(player["market_value"] * 0.95)
            save_json(FREE_AGENTS_FILE, free_agents)
    
    if expired:
        save_json(OFFERS_FILE, offers)
        print(f"Expired {len(expired)} offers")

