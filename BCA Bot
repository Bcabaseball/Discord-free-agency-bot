            "target_gm_id": target_gm_id,
            "proposing_player_id": your_pid,
            "proposing_player_name": your_p["name"],
            "target_player_id": their_pid,
            "target_player_name": their_p["name"] if their_p else None,
            "status": "pending",
            "created_at": datetime.now().isoformat(),
            "expires": (datetime.now() + timedelta(hours=48)).isoformat()
        }
        trades[trade_id] = trade
        save_json(TRADES_FILE, trades)

        # Notify the target GM
        await notify_gm(
            target_gm_id,
            f"📦 **Trade Offer from {user_team}!**\n"
            f"They are offering: **{your_p['name']}** ({your_p['position']}, OVR {your_p['ovr']})\n"
            + (f"In exchange for: **{their_p['name']}** ({their_p['position']}, OVR {their_p['ovr']})\n" if their_p else "*(No player requested in return — one-sided deal)*\n")
            + f"\nUse `/fa trade_accept` or `/fa trade_reject` to respond."
        )

