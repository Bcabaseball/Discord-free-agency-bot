# ============= CAP MANAGEMENT CLASS =============

class CapManager:
    """Manages team cap space with pending offers"""
    
    def __init__(self, team_name):
        self.team_name = team_name
        self.teams_data = load_json(TEAMS_FILE)
        self.offers_data = load_json(OFFERS_FILE)
    
    def get_available_cap(self):
        """Calculate available cap space including pending offers"""
        team = self.teams_data.get(self.team_name, {})
        total_cap = team.get("cap_space", 0)
        
        # Calculate cap used in pending offers
        pending_cap = 0
        for offer_id, offer in self.offers_data.items():
            if offer.get("team") == self.team_name and offer.get("status") == "pending":
                pending_cap += offer.get("aav", 0)
        
        return total_cap - pending_cap
    
    def can_make_offer(self, aav):
        """Check if team can afford a new offer"""
        return self.get_available_cap() >= aav

# ============= DECISION ENGINE =============

class DecisionEngine:
    """Handles free agent decision making"""
    
    @staticmethod
    def calculate_offer_score(offer, player, team, market_data):
        """Calculate total score for an offer"""
        # Get personality weights
        weights = get_personality_weights(player["personality"])
        
        # Calculate contention score
        win_pct = team.get("win_percentage", 0.500)
        contention_bonus = calculate_contention_bonus(win_pct)
        contention_score = contention_bonus * weights["contention"]
        
        # Calculate money score
        market_value = player.get("market_value", (player["min_salary"] + player["max_salary"]) / 2)
        money_base = calculate_money_score(offer["aav"], market_value, player["personality"])
        money_score = money_base * weights["money"]
        
        # Calculate length score
        length_base = calculate_length_score(
            offer["years"],
            player["ideal_length_min"],
            player["ideal_length_max"],
            player["personality"]
        )
        length_score = length_base * weights["length"]
        
        # Calculate total
        total_score = contention_score + money_score + length_score
        
        # Apply market modifiers
        total_score *= market_data.get("stage_multiplier", 1.00)
        
        # Competition modifier (harder to sign with multiple offers)
        offer_count = player.get("offer_count", 0)
        if offer_count >= 3:
            total_score *= 0.95
        elif offer_count >= 2:
            total_score *= 0.98
        
        return total_score
    
    @staticmethod
    def should_counter(score):
        """Determine if agent should counter-offer based on score"""
        if score < 0.10:
            return "reject"
        elif score < 0.20:
            return "counter_aggressive"
        elif score < 0.35:
            return "counter_moderate"
        else:
            return "accept"
    
    @staticmethod
    def generate_counter_offer(original_offer, score, personality, stage):
        """Generate counter-offer based on score and personality"""
        if score < 0.20:
            # Aggressive counter
            aav_increase = 0.20
            years_increase = 2
            strength = "weak"
        elif score < 0.35:
            # Moderate counter
            aav_increase = 0.10
            years_increase = 1
            strength = "moderate"
        else:
            return None
        
        counter_aav = int(original_offer["aav"] * (1 + aav_increase))
        counter_years = original_offer["years"] + years_increase
        
        # Ensure years don't exceed reasonable limits
        counter_years = min(counter_years, 10)
        
        return {
            "aav": counter_aav,
            "years": counter_years,
            "message": generate_counter_message(personality, strength)
        }

