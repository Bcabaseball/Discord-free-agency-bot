            return

        # Validate their player (if specified)
        their_pid, their_p = None, None
        if their_player:
            their_pid, their_p = find_player(free_agents, their_player)
            if not their_p or their_p.get("signed_team") != canonical_target:
                await interaction.response.send_message(f"❌ **{their_player}** is not on {canonical_target}'s roster.", ephemeral=True)
                return

        trades = load_json(TRADES_FILE)

        # Block if a pending trade already exists between these two for the same player
        for t in trades.values():
            if t["status"] == "pending" and t["proposing_player_id"] == your_pid and t["proposing_team"] == user_team:
                await interaction.response.send_message(f"❌ You already have a pending trade offer involving **{your_p['name']}**.", ephemeral=True)
