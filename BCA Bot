    @app_commands.command(name="trade_accept", description="Accept an incoming trade offer")
    async def trade_accept(self, interaction: discord.Interaction, trade_id: str):
        user_team, _ = get_user_team(interaction.user.id)
        if not user_team:
            await interaction.response.send_message("❌ You are not assigned to any team.", ephemeral=True)
            return

        trades = load_json(TRADES_FILE)
        # Allow short 8-char prefix match
        matched_id = next((k for k in trades if k.startswith(trade_id) or k == trade_id), None)
        if not matched_id:
            await interaction.response.send_message(f"❌ No trade found with ID `{trade_id}`.", ephemeral=True)
            return

        trade = trades[matched_id]
        if trade["target_team"] != user_team:
            await interaction.response.send_message("❌ That trade offer is not addressed to your team.", ephemeral=True)
            return
        if trade["status"] != "pending":
            await interaction.response.send_message(f"❌ This trade is already **{trade['status']}**.", ephemeral=True)
            return
        if datetime.fromisoformat(trade["expires"]) < datetime.now():
            trade["status"] = "expired"
            trades[matched_id] = trade
            save_json(TRADES_FILE, trades)
            await interaction.response.send_message("❌ This trade offer has expired.", ephemeral=True)
            return

        free_agents = load_json(FREE_AGENTS_FILE)

        # Transfer the proposing player to the target team
        proposing_pid = trade["proposing_player_id"]
        if proposing_pid and proposing_pid in free_agents:
            free_agents[proposing_pid]["signed_team"] = user_team

        # Transfer the target player to the proposing team (if any)
        target_pid = trade.get("target_player_id")
        if target_pid and target_pid in free_agents:
            free_agents[target_pid]["signed_team"] = trade["proposing_team"]

        save_json(FREE_AGENTS_FILE, free_agents)
        trade["status"] = "accepted"
        trades[matched_id] = trade
        save_json(TRADES_FILE, trades)

        log_action("trade_accepted", f"{user_team} accepted trade from {trade['proposing_team']}: {trade['proposing_player_name']} ↔ {trade.get('target_player_name', 'nothing')}")

        await notify_gm(
            trade["proposing_gm_id"],
            f"✅ **{user_team}** accepted your trade offer!\n"
            f"**{trade['proposing_player_name']}** is now on **{user_team}**."
            + (f"\n**{trade['target_player_name']}** is now on **{trade['proposing_team']}**." if trade.get("target_player_name") else "")
        )

        embed = discord.Embed(title="✅ Trade Accepted!", color=discord.Color.green())
        embed.add_field(name="You Received", value=f"**{trade['proposing_player_name']}**", inline=True)
        embed.add_field(name="You Sent", value=f"**{trade['target_player_name']}**" if trade.get("target_player_name") else "*(nothing)*", inline=True)
        await interaction.response.send_message(embed=embed, ephemeral=True)

